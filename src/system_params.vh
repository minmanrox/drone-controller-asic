`define PERIOD          3_125_000  // clock @ 3.125MHz
`define PWM_MIN         3_125      // 1ms @ 3.125MHz - base and width of pulse in PWM
`define PWM_MAX         6_250      // 2ms @ 3.125MHz
`define PWM_CENTER      4_688      // 1.5ms
`define PWM_PERIOD      62_500     // 20ms @ 3.125MHz
`define CLK_PERIOD      320        // 320ns period for 3.125MHz
