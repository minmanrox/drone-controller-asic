`define PERIOD          1_562_500  // clock @ 1.5625MHz
`define PWM_MIN         1_563      // 1ms @ 1.5625MHz - base and width of pulse in PWM
`define PWM_MAX         3_125      // 2ms @ 1.5625MHz
`define PWM_CENTER      2_344      // 1.5ms
`define PWM_PERIOD      31_250     // 20ms @ 1.5625MHz
`define CLK_PERIOD      640        // 640ns period for 1.5625MHz
